# Supabase
# Use the project URL and publishable key from Supabase Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Backward-compatible legacy name. If set, this is used when NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is absent.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI agent execution
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
